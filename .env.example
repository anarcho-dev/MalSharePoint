# Copy this file to .env and fill in the values before running the app.
# Never commit .env to version control.

# Flask
FLASK_ENV=development
SECRET_KEY=replace-with-a-random-secret-key

# JWT
JWT_SECRET_KEY=replace-with-a-random-jwt-secret

# Database (defaults to SQLite if not set)
# DATABASE_URL=sqlite:///malsharepoint.db
# DATABASE_URL=postgresql://user:password@localhost:5432/malsharepoint

# File upload
UPLOAD_FOLDER=uploads
MAX_UPLOAD_MB=100

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
